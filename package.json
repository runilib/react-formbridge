{
  "name": "@runilib/react-formbridge",
  "version": "1.0.0",
  "description": "Schema-first, headless form engine for React and React Native. Define fields once with a type-safe builder API, validate with Zod/Yup/Joi/Valibot, and render anywhere - web or native - with zero platform glue. Built-in support for multi-step wizards, dynamic JSON-driven forms, input masking, phone inputs, file uploads, async options, conditional fields, form analytics, and state persistence.",
  "keywords": [
    "react",
    "react-native",
    "form",
    "forms",
    "form-builder",
    "form-validation",
    "form-wizard",
    "multi-step-form",
    "schema",
    "schema-driven",
    "headless",
    "cross-platform",
    "universal",
    "typescript",
    "type-safe",
    "zod",
    "yup",
    "joi",
    "valibot",
    "validation",
    "input-mask",
    "dynamic-form",
    "json-form",
    "phone-input",
    "file-upload",
    "field-builder",
    "react-hooks",
    "expo"
  ],
  "homepage": "https://runilib.dev/docs/react-formbridge",
  "repository": {
    "type": "git",
    "url": "https://github.com/runilib/runilib.git",
    "directory": "packages/react-formbridge"
  },
  "bugs": {
    "url": "https://github.com/runilib/runilib/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/ton-compte"
  },
  "license": "MIT",
  "author": "AKS <tech-founder@gonextstep.io>",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "react-native": "./dist/index.native.mjs",
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/index.native.d.mts",
        "default": "./dist/index.native.mjs"
      },
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./schema": {
      "types": "./dist/schema.d.mts",
      "import": "./dist/schema.mjs",
      "default": "./dist/schema.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist coverage",
    "dev": "tsup --watch --config tsup.config.ts",
    "build": "rimraf dist && tsup --config tsup.config.ts",
    "lint": "biome lint src .",
    "lint:fix": "biome lint --write src .",
    "check": "biome check src .",
    "check:fix": "biome check --write src .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "yarn test:web && yarn test:native",
    "test:web": "vitest run",
    "test:native": "vitest run -c vitest.native.config.ts",
    "test:watch": "vitest",
    "test:watch:native": "vitest -c vitest.native.config.ts",
    "test:coverage": "vitest run --coverage",
    "tsc:build": "tsc -b tsconfig-build.json",
    "tsc:check": "tsc --noEmit",
    "tsc:watch": "tsc --noEmit --watch",
    "prepack": "node ../../scripts/package-pack-sourcemaps.mjs hide",
    "postpack": "node ../../scripts/package-pack-sourcemaps.mjs restore",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "react-native": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "^14.0.0",
    "@testing-library/react-native": "^12.4.3",
    "@tsconfig/react-native": "^3.0.3",
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-test-renderer": "^18.0.7",
    "@vitest/coverage-v8": "^4.1.1",
    "jsdom": "^26.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "^0.76.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "libphonenumber-js": "^1.12.40"
  }
}
