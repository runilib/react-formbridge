{
  "name": "@runilib/react-formbridge",
  "version": "1.0.0",
  "description": "Schema-first, cross-platform forms for React and React Native. One schema, one API, every platform.",
  "keywords": [
    "react",
    "react-native",
    "form",
    "validation",
    "schema",
    "cross-platform",
    "universal",
    "typescript"
  ],
  "homepage": "https://runilib.dev/docs/react-formbridge",
  "repository": {
    "type": "git",
    "url": "https://github.com/runilib/runilib.git",
    "directory": "packages/react-formbridge"
  },
  "bugs": {
    "url": "https://github.com/runilib/runilib/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/ton-compte"
  },
  "license": "MIT",
  "author": "AKS <tech-founder@gonextstep.io>",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "react-native": "./dist/index.native.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "react-native": "./dist/index.native.mjs",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist coverage",
    "dev": "tsup --watch --config tsup.config.ts",
    "build": "rimraf dist && tsup --config tsup.config.ts",
    "lint": "biome lint src .",
    "lint:fix": "biome lint --write src .",
    "check": "biome check src .",
    "check:fix": "biome check --write src .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tsc:build": "tsc -b tsconfig-build.json",
    "tsc:check": "tsc --noEmit",
    "tsc:watch": "tsc --noEmit --watch",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "react-native": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "^14.0.0",
    "@testing-library/react-native": "^12.4.3",
    "@tsconfig/react-native": "^3.0.3",
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-test-renderer": "^18.0.7",
    "@vitest/coverage-v8": "^4.1.1",
    "jsdom": "^26.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "^0.76.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "libphonenumber-js": "^1.12.40"
  }
}
