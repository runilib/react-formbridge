{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "customConditions": ["react-native"],
    "resolvePackageJsonImports": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "types": ["node", "react"],
    "declaration": true,
    "noEmit": false,
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "**/*.test.*", "**/*.spec.*", "**/__tests__/**"]
}